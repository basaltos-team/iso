#!/usr/bin/env sh
set -eu

DISK=""
HOSTNAME="basalt"
TARGET="/mnt"
REPO_SERVER=""
LOCALE="en_US.UTF-8"
KEYMAP="us"
TIMEZONE="UTC"
USERNAME="omega24"
PASSWORD="basalt"
DRY_RUN=0
YES=0

usage() {
  cat <<'EOF'
Usage: basalt-install --disk /dev/vda [options]

Options:
  --disk PATH       Target disk to erase and install to.
  --hostname NAME   Installed hostname. Default: basalt.
  --target PATH     Mounted install root. Default: /mnt.
  --repo URL        Optional pacman repo server, for example file:///tmp/basalt-local-repo.
  --locale LOCALE   Installed locale. Default: en_US.UTF-8.
  --keymap KEYMAP   Installed console keymap. Default: us.
  --timezone ZONE   Installed timezone. Default: UTC.
  --user NAME       Installed test user. Default: omega24.
  --password TEXT   Initial test user password. Default: basalt.
  --dry-run         Print the install plan without changing disks.
  --yes             Execute the install plan after WIPE confirmation.
  --help            Show this help.

The real install path erases the target disk. It requires --yes and the
confirmation word WIPE on stdin or BASALT_INSTALL_CONFIRM=WIPE.
EOF
}

fail() {
  printf 'FAIL: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "required command not found: $1"
}

partition_path() {
  case "$1" in
    *[0-9]) printf '%sp%s\n' "$1" "$2" ;;
    *) printf '%s%s\n' "$1" "$2" ;;
  esac
}

run() {
  printf '+ %s\n' "$*"
  if [ "$DRY_RUN" -eq 0 ]; then
    "$@"
  fi
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --disk)
      [ "$#" -ge 2 ] || fail "--disk requires a value"
      DISK="$2"
      shift 2
      ;;
    --hostname)
      [ "$#" -ge 2 ] || fail "--hostname requires a value"
      HOSTNAME="$2"
      shift 2
      ;;
    --target)
      [ "$#" -ge 2 ] || fail "--target requires a value"
      TARGET="$2"
      shift 2
      ;;
    --repo)
      [ "$#" -ge 2 ] || fail "--repo requires a value"
      REPO_SERVER="$2"
      shift 2
      ;;
    --locale)
      [ "$#" -ge 2 ] || fail "--locale requires a value"
      LOCALE="$2"
      shift 2
      ;;
    --keymap)
      [ "$#" -ge 2 ] || fail "--keymap requires a value"
      KEYMAP="$2"
      shift 2
      ;;
    --timezone)
      [ "$#" -ge 2 ] || fail "--timezone requires a value"
      TIMEZONE="$2"
      shift 2
      ;;
    --user)
      [ "$#" -ge 2 ] || fail "--user requires a value"
      USERNAME="$2"
      shift 2
      ;;
    --password)
      [ "$#" -ge 2 ] || fail "--password requires a value"
      PASSWORD="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --yes)
      YES=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      fail "unknown argument: $1"
      ;;
  esac
done

[ -n "$DISK" ] || fail "--disk is required"
[ -n "$HOSTNAME" ] || fail "--hostname cannot be empty"
[ -n "$TARGET" ] || fail "--target cannot be empty"
[ -n "$LOCALE" ] || fail "--locale cannot be empty"
[ -n "$KEYMAP" ] || fail "--keymap cannot be empty"
[ -n "$TIMEZONE" ] || fail "--timezone cannot be empty"
[ -n "$USERNAME" ] || fail "--user cannot be empty"
[ -n "$PASSWORD" ] || fail "--password cannot be empty"

BIOS_PART="$(partition_path "$DISK" 1)"
EFI_PART="$(partition_path "$DISK" 2)"
ROOT_PART="$(partition_path "$DISK" 3)"
PACMAN_CONF="/tmp/basalt-install-pacman.conf"

printf 'BasaltOS install plan\n'
printf 'Disk:       %s\n' "$DISK"
printf 'BIOS boot:  %s\n' "$BIOS_PART"
printf 'EFI:        %s\n' "$EFI_PART"
printf 'Root:       %s\n' "$ROOT_PART"
printf 'Target:     %s\n' "$TARGET"
printf 'Hostname:   %s\n' "$HOSTNAME"
printf 'Locale:     %s\n' "$LOCALE"
printf 'Keymap:     %s\n' "$KEYMAP"
printf 'Timezone:   %s\n' "$TIMEZONE"
printf 'User:       %s\n' "$USERNAME"
if [ -n "$REPO_SERVER" ]; then
  printf 'Repo:       %s\n' "$REPO_SERVER"
else
  printf 'Repo:       system pacman configuration\n'
fi
printf 'Packages:   basalt-base linux linux-firmware dracut grub openssh\n'

if [ "$DRY_RUN" -eq 1 ]; then
  printf 'Mode:       dry-run\n'
  exit 0
fi

[ "$YES" -eq 1 ] || fail "real install requires --yes"

CONFIRM="${BASALT_INSTALL_CONFIRM:-}"
if [ -z "$CONFIRM" ]; then
  printf 'Type WIPE to erase %s: ' "$DISK" >&2
  read -r CONFIRM
fi
[ "$CONFIRM" = "WIPE" ] || fail "aborted"

require_cmd sgdisk
require_cmd wipefs
require_cmd mkfs.fat
require_cmd mkfs.ext4
require_cmd mount
require_cmd partprobe
require_cmd blkid
require_cmd pacstrap
require_cmd genfstab
require_cmd arch-chroot

printf '+ umount -R %s\n' "$TARGET"
umount -R "$TARGET" 2>/dev/null || true
run wipefs -af "$DISK"
run sgdisk --zap-all "$DISK"
run sgdisk -n 1:1MiB:+2MiB -t 1:ef02 -c 1:BIOS "$DISK"
run sgdisk -n 2:3MiB:+512MiB -t 2:ef00 -c 2:EFI "$DISK"
run sgdisk -n 3:0:0 -t 3:8300 -c 3:ROOT "$DISK"
run partprobe "$DISK"
run mkfs.fat -F32 "$EFI_PART"
run mkfs.ext4 -F "$ROOT_PART"
ROOT_UUID="$(blkid -s UUID -o value "$ROOT_PART")"
[ -n "$ROOT_UUID" ] || fail "could not read UUID for $ROOT_PART"
run mkdir -p "$TARGET"
run mount "$ROOT_PART" "$TARGET"
run mkdir -p "$TARGET/boot"
run mount "$EFI_PART" "$TARGET/boot"
run mkdir -p "$TARGET/etc"
printf 'LANG=%s\n' "$LOCALE" > "$TARGET/etc/locale.conf"
printf 'KEYMAP=%s\n' "$KEYMAP" > "$TARGET/etc/vconsole.conf"

if [ -n "$REPO_SERVER" ]; then
  cp /etc/pacman.conf "$PACMAN_CONF"
  printf '\n[basalt]\nSigLevel = Optional TrustAll\nServer = %s\n' "$REPO_SERVER" >> "$PACMAN_CONF"
  run pacstrap -K -C "$PACMAN_CONF" "$TARGET" basalt-base linux linux-firmware dracut grub openssh
else
  run pacstrap -K "$TARGET" basalt-base linux linux-firmware dracut grub openssh
fi

genfstab -U "$TARGET" >> "$TARGET/etc/fstab"
printf '%s\n' "$HOSTNAME" > "$TARGET/etc/hostname"
mkdir -p "$TARGET/etc/systemd/network" "$TARGET/etc/ssh/sshd_config.d"
cat > "$TARGET/etc/systemd/network/20-wired.network" <<'EOF'
[Match]
Name=en* eth*

[Network]
DHCP=yes
EOF
cat > "$TARGET/etc/ssh/sshd_config.d/10-basalt-install.conf" <<'EOF'
PasswordAuthentication yes
PermitRootLogin no
EOF
cat > "$TARGET/etc/default/grub" <<'EOF'
GRUB_DISTRIBUTOR="BasaltOS"
GRUB_DEFAULT=0
GRUB_TIMEOUT=5
GRUB_CMDLINE_LINUX_DEFAULT="quiet"
GRUB_CMDLINE_LINUX=""
EOF
run arch-chroot "$TARGET" ln -sf "/usr/share/zoneinfo/$TIMEZONE" /etc/localtime
run arch-chroot "$TARGET" useradd -m -G wheel "$USERNAME"
printf '%s:%s\n' "$USERNAME" "$PASSWORD" | arch-chroot "$TARGET" chpasswd
run arch-chroot "$TARGET" systemctl enable sshd systemd-networkd
run mkdir -p "$TARGET/boot/grub"
printf '(hd0) %s\n' "$DISK" > "$TARGET/boot/grub/device.map"
run arch-chroot "$TARGET" grub-install --target=i386-pc --recheck "$DISK"
run arch-chroot "$TARGET" grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=BasaltOS --removable
run arch-chroot "$TARGET" grub-mkconfig -o /boot/grub/grub.cfg
if [ ! -f "$TARGET/boot/grub/grub.cfg" ] && [ -f "$TARGET/boot/grub/grub.cfg.new" ]; then
  run mv "$TARGET/boot/grub/grub.cfg.new" "$TARGET/boot/grub/grub.cfg"
fi
[ -f "$TARGET/boot/grub/grub.cfg" ] || fail "grub configuration was not generated at /boot/grub/grub.cfg"
run arch-chroot "$TARGET" bootctl --esp-path=/boot --no-variables install
mkdir -p "$TARGET/boot/EFI/BOOT" "$TARGET/boot/loader/entries"
cp "$TARGET/boot/EFI/systemd/systemd-bootx64.efi" "$TARGET/boot/EFI/BOOT/BOOTX64.EFI"
cat > "$TARGET/boot/loader/loader.conf" <<'EOF'
default basalt.conf
timeout 3
console-mode max
editor no
EOF
cat > "$TARGET/boot/loader/entries/basalt.conf" <<EOF
title BasaltOS
linux /vmlinuz-linux
initrd /initramfs-linux.img
options root=UUID=$ROOT_UUID rw
EOF
run sync
printf '+ umount -R %s\n' "$TARGET"
if [ "$DRY_RUN" -eq 0 ]; then
  umount -R "$TARGET" || umount -Rl "$TARGET"
fi

printf 'BasaltOS install complete at %s\n' "$TARGET"
