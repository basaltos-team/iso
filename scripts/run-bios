#!/usr/bin/env sh
set -eu

ISO_PATH="${BASALT_ISO_PATH:-}"
MEMORY="${BASALT_ISO_MEMORY:-4096}"
CPUS="${BASALT_ISO_CPUS:-4}"

[ -n "$ISO_PATH" ] || {
  printf 'FAIL: set BASALT_ISO_PATH=/path/to/basaltos.iso\n' >&2
  exit 1
}

test -s "$ISO_PATH"
command -v qemu-system-x86_64 >/dev/null 2>&1 || {
  printf 'FAIL: qemu-system-x86_64 is not available\n' >&2
  exit 1
}

exec qemu-system-x86_64 \
  -enable-kvm \
  -machine type=q35,accel=kvm \
  -cpu host \
  -smp "$CPUS" \
  -m "$MEMORY" \
  -cdrom "$ISO_PATH" \
  -boot d \
  -display gtk
