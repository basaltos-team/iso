#!/usr/bin/env sh
set -eu

ISO_PATH="${BASALT_ISO_PATH:-}"
MEMORY="${BASALT_ISO_MEMORY:-4096}"
CPUS="${BASALT_ISO_CPUS:-4}"
STATE_DIR="${BASALT_ISO_STATE_DIR:-/tmp/basalt-iso-vm}"
DISPLAY_MODE="${BASALT_ISO_DISPLAY:-gtk}"
SERIAL_LOG="${BASALT_ISO_SERIAL_LOG:-}"

find_ovmf_file() {
  if [ -n "${1:-}" ] && [ -f "$1" ]; then
    printf '%s\n' "$1"
    return 0
  fi

  for path in \
    "/run/current-system/sw/share/qemu/$2" \
    "/run/current-system/sw/share/OVMF/FV/$2"
  do
    if [ -f "$path" ]; then
      printf '%s\n' "$path"
      return 0
    fi
  done

  find /nix/store -maxdepth 5 -path "*/FV/$2" -type f 2>/dev/null | sort | tail -n 1
}

[ -n "$ISO_PATH" ] || {
  printf 'FAIL: set BASALT_ISO_PATH=/path/to/basaltos.iso\n' >&2
  exit 1
}

test -s "$ISO_PATH"
command -v qemu-system-x86_64 >/dev/null 2>&1 || {
  printf 'FAIL: qemu-system-x86_64 is not available\n' >&2
  exit 1
}

OVMF_CODE="$(find_ovmf_file "${BASALT_OVMF_CODE:-}" OVMF_CODE.fd)"
OVMF_VARS_SOURCE="$(find_ovmf_file "${BASALT_OVMF_VARS:-}" OVMF_VARS.fd)"
[ -n "$OVMF_CODE" ] && [ -f "$OVMF_CODE" ] || {
  printf 'FAIL: OVMF_CODE.fd not found. Set BASALT_OVMF_CODE=/path/to/OVMF_CODE.fd\n' >&2
  exit 1
}
[ -n "$OVMF_VARS_SOURCE" ] && [ -f "$OVMF_VARS_SOURCE" ] || {
  printf 'FAIL: OVMF_VARS.fd not found. Set BASALT_OVMF_VARS=/path/to/OVMF_VARS.fd\n' >&2
  exit 1
}

mkdir -p "$STATE_DIR"
OVMF_VARS="$STATE_DIR/OVMF_VARS.fd"
rm -f "$OVMF_VARS"
cp "$OVMF_VARS_SOURCE" "$OVMF_VARS"
chmod 0600 "$OVMF_VARS"

set -- qemu-system-x86_64 \
  -enable-kvm \
  -machine type=q35,accel=kvm \
  -cpu host \
  -smp "$CPUS" \
  -m "$MEMORY" \
  -drive "if=pflash,format=raw,readonly=on,file=$OVMF_CODE" \
  -drive "if=pflash,format=raw,file=$OVMF_VARS" \
  -cdrom "$ISO_PATH" \
  -boot d

case "$DISPLAY_MODE" in
  gtk)
    set -- "$@" -display gtk
    ;;
  none)
    set -- "$@" -display none
    ;;
  *)
    printf 'FAIL: unknown BASALT_ISO_DISPLAY mode: %s\n' "$DISPLAY_MODE" >&2
    exit 1
    ;;
esac

if [ -n "$SERIAL_LOG" ]; then
  set -- "$@" -serial "file:$SERIAL_LOG"
fi

exec "$@"
